@model MyRequestListViewModel
@{
    ViewData["Title"] = "My Requests";
    ViewData["Subtitle"] = "Your asset requests";
    var r = Model.Results;
}

<div class="page-actions">
    <div></div>
    <a class="btn btn-primary" asp-action="Create">+ New request</a>
</div>

<div class="card">
    <form method="get" asp-action="Index" class="filters">
        <div class="filter-item">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value="">All</option>
                @foreach (var s in Enum.GetValues<RequestStatus>())
                {
                    <option value="@s" selected="@(Model.Status == s)">@s</option>
                }
            </select>
        </div>
        <div class="filter-item">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
        <div class="filter-item">
            <a class="btn btn-secondary" asp-action="Index">Reset</a>
        </div>
    </form>

    <div class="table-wrap">
        <table class="grid">
            <thead>
                <tr>
                    <th>Request</th>
                    <th>Category</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th class="nowrap">Requested</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!r.Items.Any())
                {
                    <tr><td colspan="6" class="text-muted">You have no requests yet.</td></tr>
                }
                @foreach (var req in r.Items)
                {
                    <tr>
                        <td class="nowrap"><strong>@req.RequestNumber</strong></td>
                        <td>@(req.AssetCategory?.Name ?? "—")</td>
                        <td>@req.Priority</td>
                        <td><span class="@DisplayHelpers.BadgeClass(req.Status)">@req.Status</span></td>
                        <td class="nowrap text-muted">@req.RequestedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-right nowrap">
                            <a class="btn btn-sm btn-secondary" asp-action="Details" asp-route-id="@req.Id">View</a>
                            @if (req.Status == RequestStatus.Pending)
                            {
                                <form method="post" asp-action="Cancel" asp-route-id="@req.Id" style="display:inline;" data-confirm="Cancel request @req.RequestNumber?">
                                    <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pager" model="@(new PagerContext(r.Page, r.TotalPages, r.FirstItemOnPage, r.LastItemOnPage, r.TotalCount))" />
</div>
