@model ApprovalListViewModel
@{
    ViewData["Title"] = "Approvals";
    ViewData["Subtitle"] = "Review and action asset requests";
    var r = Model.Results;
}

<div class="card">
    <form method="get" asp-action="Index" class="filters">
        <div class="filter-item">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value="">Pending (default)</option>
                @foreach (var s in Enum.GetValues<RequestStatus>())
                {
                    <option value="@s" selected="@(Model.Status == s)">@s</option>
                }
            </select>
        </div>
        <div class="filter-item">
            <label>Category</label>
            <select name="categoryId" class="form-control">
                <option value="">All categories</option>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <div class="filter-item">
            <label>Priority</label>
            <select name="priority" class="form-control">
                <option value="">All</option>
                @foreach (var p in Enum.GetValues<RequestPriority>())
                {
                    <option value="@p" selected="@(Model.Priority == p)">@p</option>
                }
            </select>
        </div>
        <div class="filter-item">
            <label>From</label>
            <input type="date" name="fromDate" class="form-control" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="filter-item">
            <label>To</label>
            <input type="date" name="toDate" class="form-control" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="filter-item">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
        <div class="filter-item">
            <a class="btn btn-secondary" asp-action="Index">Reset</a>
        </div>
    </form>

    <div class="table-wrap">
        <table class="grid">
            <thead>
                <tr>
                    <th>Request</th>
                    <th>Requested By</th>
                    <th>Category</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th class="nowrap">Requested</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!r.Items.Any())
                {
                    <tr><td colspan="7" class="text-muted">No requests match your filters.</td></tr>
                }
                @foreach (var req in r.Items)
                {
                    <tr>
                        <td class="nowrap"><strong>@req.RequestNumber</strong></td>
                        <td>@(req.RequestedByUser?.FullName ?? "—")</td>
                        <td>@(req.AssetCategory?.Name ?? "—")</td>
                        <td>@req.Priority</td>
                        <td><span class="@DisplayHelpers.BadgeClass(req.Status)">@req.Status</span></td>
                        <td class="nowrap text-muted">@req.RequestedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-right nowrap">
                            <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@req.Id">Review</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pager" model="@(new PagerContext(r.Page, r.TotalPages, r.FirstItemOnPage, r.LastItemOnPage, r.TotalCount))" />
</div>
