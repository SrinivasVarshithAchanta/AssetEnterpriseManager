@model UserCreateViewModel
@{
    ViewData["Title"] = "Add user";
    ViewData["Subtitle"] = "Create a new user account";
    var roleOptions = new SelectList(new[] { Roles.Admin, Roles.Manager, Roles.Employee }, Model.Role);
}

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Create" class="form">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="form-row">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="name@assetops.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" />
                <div class="help">Minimum 6 characters. Stored only as a salted hash.</div>
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Role"></label>
                <select asp-for="Role" class="form-control" asp-items="roleOptions"></select>
                <span asp-validation-for="Role" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Department"></label>
                <input asp-for="Department" class="form-control" placeholder="Engineering" />
                <span asp-validation-for="Department" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="checkbox-row">
                    <input asp-for="IsActive" type="checkbox" />
                    <label asp-for="IsActive" style="margin:0;"></label>
                </div>
            </div>

            <div class="btn-row">
                <button type="submit" class="btn btn-primary">Create user</button>
                <a class="btn btn-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
