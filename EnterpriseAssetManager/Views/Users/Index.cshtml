@model UserListViewModel
@{
    ViewData["Title"] = "Users";
    ViewData["Subtitle"] = "Manage organization users";
    var r = Model.Results;
    var allRoles = new[] { Roles.Admin, Roles.Manager, Roles.Employee };
}

<div class="page-actions">
    <div></div>
    <a class="btn btn-primary" asp-action="Create">+ Add user</a>
</div>

<div class="card">
    <form method="get" asp-action="Index" class="filters">
        <div class="filter-item">
            <label>Search</label>
            <input class="form-control" name="search" value="@Model.Search" placeholder="Name or email" />
        </div>
        <div class="filter-item">
            <label>Role</label>
            <select name="role" class="form-control">
                <option value="">All roles</option>
                @foreach (var role in allRoles)
                {
                    <option value="@role" selected="@(Model.Role == role)">@role</option>
                }
            </select>
        </div>
        <div class="filter-item">
            <label>Status</label>
            <select name="isActive" class="form-control">
                <option value="">All</option>
                <option value="true" selected="@(Model.IsActive == true)">Active</option>
                <option value="false" selected="@(Model.IsActive == false)">Inactive</option>
            </select>
        </div>
        <div class="filter-item">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
        <div class="filter-item">
            <a class="btn btn-secondary" asp-action="Index">Reset</a>
        </div>
    </form>

    <div class="table-wrap">
        <table class="grid">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Department</th>
                    <th>Status</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!r.Items.Any())
                {
                    <tr><td colspan="6" class="text-muted">No users match your filters.</td></tr>
                }
                @foreach (var u in r.Items)
                {
                    <tr>
                        <td><strong>@u.FullName</strong></td>
                        <td class="text-muted">@u.Email</td>
                        <td><span class="badge badge-role">@u.Role</span></td>
                        <td>@(string.IsNullOrWhiteSpace(u.Department) ? "—" : u.Department)</td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span class="badge badge-available">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-retired">Inactive</span>
                            }
                        </td>
                        <td class="text-right nowrap">
                            <a class="btn btn-sm btn-secondary" asp-action="Edit" asp-route-id="@u.Id">Edit</a>
                            <form method="post" asp-action="SetActive" asp-route-id="@u.Id" asp-route-isActive="@(!u.IsActive)" style="display:inline;"
                                  data-confirm="@(u.IsActive ? "Deactivate" : "Activate") @u.FullName?">
                                <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-danger" : "btn-success")">
                                    @(u.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pager" model="@(new PagerContext(r.Page, r.TotalPages, r.FirstItemOnPage, r.LastItemOnPage, r.TotalCount))" />
</div>
