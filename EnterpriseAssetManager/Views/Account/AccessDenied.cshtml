@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access denied - AssetOps</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="centered-msg">
    <div class="big">403</div>
    <h1>Access denied</h1>
    <p class="text-muted">You do not have permission to view this page with your current role.</p>
    <div class="btn-row" style="margin-top:16px;">
        <a class="btn btn-primary" asp-controller="Dashboard" asp-action="Index">Go to dashboard</a>
    </div>
</div>
</body>
</html>
