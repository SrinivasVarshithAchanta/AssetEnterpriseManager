@model AuditLogListViewModel
@{
    ViewData["Title"] = "Audit Logs";
    ViewData["Subtitle"] = "System activity trail";
    var r = Model.Results;
}

<div class="card">
    <form method="get" asp-action="Index" class="filters">
        <div class="filter-item">
            <label>Search</label>
            <input class="form-control" name="search" value="@Model.Search" placeholder="Action, entity, user or details" />
        </div>
        <div class="filter-item">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
        <div class="filter-item">
            <a class="btn btn-secondary" asp-action="Index">Reset</a>
        </div>
    </form>

    <div class="table-wrap">
        <table class="grid">
            <thead>
                <tr>
                    <th class="nowrap">When</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @if (!r.Items.Any())
                {
                    <tr><td colspan="5" class="text-muted">No audit entries found.</td></tr>
                }
                @foreach (var log in r.Items)
                {
                    <tr>
                        <td class="nowrap text-muted">@log.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@(log.User?.FullName ?? "System")</td>
                        <td><strong>@log.Action</strong></td>
                        <td>@log.EntityName@(log.EntityId.HasValue ? $" #{log.EntityId}" : "")</td>
                        <td class="text-muted">@log.Details</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pager" model="@(new PagerContext(r.Page, r.TotalPages, r.FirstItemOnPage, r.LastItemOnPage, r.TotalCount))" />
</div>
