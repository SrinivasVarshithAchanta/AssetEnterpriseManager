@model AssetCreateViewModel
@{
    ViewData["Title"] = "Add asset";
    ViewData["Subtitle"] = "Register a new asset in the inventory";
}

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Create" class="form">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="form-row">
                <label asp-for="AssetTag"></label>
                <input asp-for="AssetTag" class="form-control" placeholder="AST-1001" />
                <div class="help">Unique identifier printed on the asset label.</div>
                <span asp-validation-for="AssetTag" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" placeholder="Dell Latitude 5440" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="CategoryId"></label>
                <select asp-for="CategoryId" class="form-control" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))">
                    <option value="">Select a category</option>
                </select>
                <span asp-validation-for="CategoryId" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="SerialNumber"></label>
                <input asp-for="SerialNumber" class="form-control" placeholder="SN-123456" />
                <span asp-validation-for="SerialNumber" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Status"></label>
                <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<AssetStatus>()"></select>
                <span asp-validation-for="Status" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Condition"></label>
                <select asp-for="Condition" class="form-control" asp-items="Html.GetEnumSelectList<AssetCondition>()"></select>
                <span asp-validation-for="Condition" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="PurchaseDate"></label>
                <input asp-for="PurchaseDate" type="date" class="form-control" />
                <span asp-validation-for="PurchaseDate" class="field-validation-error"></span>
            </div>

            <div class="btn-row">
                <button type="submit" class="btn btn-primary">Save asset</button>
                <a class="btn btn-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
