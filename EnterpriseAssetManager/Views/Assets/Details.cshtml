@model Asset
@{
    ViewData["Title"] = "Asset details";
    ViewData["Subtitle"] = Model.AssetTag;
    var isAdmin = User.IsInRole(Roles.Admin);
}

<div class="page-actions">
    <a class="btn btn-secondary" asp-action="Index">‹ Back to assets</a>
    @if (isAdmin)
    {
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit asset</a>
    }
</div>

<div class="card">
    <div class="card-head"><h2>@Model.Name</h2><span class="@DisplayHelpers.BadgeClass(Model.Status)">@DisplayHelpers.Friendly(Model.Status)</span></div>
    <div class="card-body">
        <div class="detail-grid">
            <div class="item"><div class="k">Asset Tag</div><div class="v">@Model.AssetTag</div></div>
            <div class="item"><div class="k">Category</div><div class="v">@(Model.Category?.Name ?? "—")</div></div>
            <div class="item"><div class="k">Serial Number</div><div class="v">@Model.SerialNumber</div></div>
            <div class="item"><div class="k">Condition</div><div class="v">@Model.Condition</div></div>
            <div class="item"><div class="k">Assigned To</div><div class="v">@(Model.AssignedToUser?.FullName ?? "Unassigned")</div></div>
            <div class="item"><div class="k">Purchase Date</div><div class="v">@Model.PurchaseDate.ToString("dd MMM yyyy")</div></div>
            <div class="item"><div class="k">Created</div><div class="v">@Model.CreatedAt.ToString("dd MMM yyyy")</div></div>
            <div class="item"><div class="k">Last Updated</div><div class="v">@(Model.UpdatedAt?.ToString("dd MMM yyyy") ?? "—")</div></div>
        </div>
    </div>
</div>
