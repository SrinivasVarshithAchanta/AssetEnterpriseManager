@model AssetListViewModel
@{
    ViewData["Title"] = "Assets";
    ViewData["Subtitle"] = "Company asset inventory";
    var r = Model.Results;
    var isAdmin = User.IsInRole(Roles.Admin);
}

<div class="page-actions">
    <div></div>
    @if (isAdmin)
    {
        <a class="btn btn-primary" asp-action="Create">+ Add asset</a>
    }
</div>

<div class="card">
    <form method="get" asp-action="Index" class="filters">
        <div class="filter-item">
            <label>Search</label>
            <input class="form-control" name="search" value="@Model.Search" placeholder="Tag, name or serial" />
        </div>
        <div class="filter-item">
            <label>Category</label>
            <select name="categoryId" class="form-control">
                <option value="">All categories</option>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <div class="filter-item">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value="">All</option>
                @foreach (var s in Enum.GetValues<AssetStatus>())
                {
                    <option value="@s" selected="@(Model.Status == s)">@DisplayHelpers.Friendly(s)</option>
                }
            </select>
        </div>
        <div class="filter-item">
            <label>Condition</label>
            <select name="condition" class="form-control">
                <option value="">All</option>
                @foreach (var c in Enum.GetValues<AssetCondition>())
                {
                    <option value="@c" selected="@(Model.Condition == c)">@c</option>
                }
            </select>
        </div>
        <div class="filter-item">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
        <div class="filter-item">
            <a class="btn btn-secondary" asp-action="Index">Reset</a>
        </div>
    </form>

    <div class="table-wrap">
        <table class="grid">
            <thead>
                <tr>
                    <th>Asset Tag</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Serial</th>
                    <th>Status</th>
                    <th>Condition</th>
                    <th>Assigned To</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!r.Items.Any())
                {
                    <tr><td colspan="8" class="text-muted">No assets match your filters.</td></tr>
                }
                @foreach (var a in r.Items)
                {
                    <tr>
                        <td class="nowrap"><strong>@a.AssetTag</strong></td>
                        <td>@a.Name</td>
                        <td>@(a.Category?.Name ?? "—")</td>
                        <td class="text-muted">@a.SerialNumber</td>
                        <td><span class="@DisplayHelpers.BadgeClass(a.Status)">@DisplayHelpers.Friendly(a.Status)</span></td>
                        <td>@a.Condition</td>
                        <td>@(a.AssignedToUser?.FullName ?? "—")</td>
                        <td class="text-right nowrap">
                            <a class="btn btn-sm btn-secondary" asp-action="Details" asp-route-id="@a.Id">View</a>
                            @if (isAdmin)
                            {
                                <a class="btn btn-sm btn-secondary" asp-action="Edit" asp-route-id="@a.Id">Edit</a>
                                @if (a.Status != AssetStatus.Retired)
                                {
                                    <form method="post" asp-action="Retire" asp-route-id="@a.Id" style="display:inline;" data-confirm="Retire asset @a.AssetTag?">
                                        <button type="submit" class="btn btn-sm btn-danger">Retire</button>
                                    </form>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pager" model="@(new PagerContext(r.Page, r.TotalPages, r.FirstItemOnPage, r.LastItemOnPage, r.TotalCount))" />
</div>
